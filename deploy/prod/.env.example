DEPLOY_IMAGE=ghcr.io/example/traffic-data:sha-override

DEPLOY_POSTGRES_DB=traffic_data
DEPLOY_POSTGRES_USER=postgres
DEPLOY_POSTGRES_PASSWORD=postgres

DEPLOY_POSTGREST_DB_URI=postgres://authenticator:localdev_authenticator_password@postgres:5432/traffic_data
DEPLOY_POSTGREST_JWT_SECRET=super-secret-admin-key-for-local-dev-32
DEPLOY_POSTGREST_ANON_ROLE=web_anon
DEPLOY_POSTGREST_ADMIN_ROLE=traffic_admin

DEPLOY_APP_PORT=3000
DEPLOY_POSTGREST_PORT=3001
DEPLOY_PUBLIC_POSTGREST_URL=http://127.0.0.1:3001

